  "keyFeatures": [
    "Google ADK integration with custom Ollama model support via @yagolopez/adk-utils",
    "Modern chat UI with streaming responses and markdown rendering",
    "Mermaid.js diagram generation for visual representations",
    "Built-in agent tools for time retrieval and code visualization",
    "Rate limiting with @tanstack/react-pacer",
    "Next.js 16 with React 19 and App Router"
  ],
  "publicApiSurface": [
    "POST /api/genai-agent - Main agent communication endpoint",
    "rootAgent - Primary ADK agent with tools",
    "OllamaModel - Custom model from @yagolopez/adk-utils",
    "GenAIAgentService - Service utility from @yagolopez/adk-utils",
    "getCurrentTime - Tool for retrieving city time",
    "createMermaidDiagram - Tool for generating diagrams",
    "viewSourceCode - Tool for displaying source code",
    "ChatHeader - Header component",
    "ChatInput - Input component with rate limiting",
    "ChatMessage - Message display component",
    "ChatEmptyState - Empty state component",
    "ChatTypingIndicator - Typing indicator component",
    "useScrollToBottom - Auto-scroll hook",
    "useFocusOnLoad - Focus management hook"
  ]
